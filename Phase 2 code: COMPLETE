;Traffic Light Controller using EMU8086
;Rhooti: Nour Makhoul, Whitney Hollman, Ignacio Mora

ORG 100h

;In this code, DX is like an integer to hold state number 
PED_REQ DB 0  ;pedestrian request flag (0 = no request, 1 = request)

MAIN PROC
 MAIN_LOOP: 
   ;state 1 NS Green & EW Red
   STATE_1:  
      MOV DX, 1  ;storing current state number
      CALL NS_GREEN_LIGHT
      CALL CHECK_INPUT 
      JMP STATE_2
   
   ;state 2 NS Yellow & EW Red     
   STATE_2:
      MOV DX, 2 
      CALL NS_YELLOW_LIGHT
      CALL CHECK_INPUT
      JMP STATE_3
   
   ;state 3 all Red for a safe transition
   ;pedestrian request is honored here
   STATE_3:
      MOV DX, 3
      CALL ALL_RED_LIGHT
      CALL CHECK_INPUT
      JMP STATE_4   
      
   ;state 4 NS Red & EW Green
   STATE_4:
      MOV DX, 4
      CALL NS_RED_LIGHT
      CALL CHECK_INPUT
      JMP STATE_5   
      
   ;state 5 NS Red & EW Yellow
   STATE_5: 
      MOV DX, 5
      CALL EW_YELLOW_LIGHT
      CALL CHECK_INPUT
      JMP STATE_6 
      
   ;state 6 all Red for a safe transition
   ;pedestrian request is honored here
   STATE_6:
      MOV DX, 6
      CALL ALL_RED_LIGHT
      CALL CHECK_INPUT
      JMP STATE_1
      
    JMP MAIN_LOOP
    
MAIN ENDP

;----Check Input----
;non blocking keyboard read for emergency and pedestrian
CHECK_INPUT PROC
   
    MOV AH, 06h 
    MOV DL, 0FFh
    INT 21h
    JZ NO_KEY

    ;emergency input, immediate interrupt
    CMP AL, 'E' ;emergency detected  
    JE  EMERGENCY
    CMP AL, 'e' ;emergency detected
    JE  EMERGENCY

    ;pedestrian input, waits for a safe moment
    CMP AL, 'P' ;pedestrian detected
    JE  PEDESTRIAN 
    CMP AL, 'p' ;pedestrian detected
    JE  PEDESTRIAN   

    JMP NO_KEY  

;using stacks in emergency to save/restore state
EMERGENCY:
    PUSH DX  ;save state number
    CALL EMERGENCY_MODE 
    POP DX   ;restore state number
    JMP RETURN   ;jump back to correct state

;waits for next safe all-red phase
PEDESTRIAN: 
    MOV PED_REQ, 1  ;set pedestrian flag
    RET   

;return to correct state after emergency
RETURN:
    CMP DX, 1
    JE STATE_1
    CMP DX, 2
    JE STATE_2
    CMP DX, 3
    JE STATE_3
    CMP DX, 4
    JE STATE_4
    CMP DX, 5
    JE STATE_5
    CMP DX, 6
    JE STATE_6
    JMP MAIN_LOOP

NO_KEY:
    RET  
CHECK_INPUT ENDP

;---- North South Green Light & East West Red Light---- 
NS_GREEN_LIGHT PROC 
    MOV AX, 30Ch
    OUT 4, AX
  
    MOV CX, 100 ;t 
    NSG_LOOP:           
      CALL CHECK_INPUT
      LOOP NSG_LOOP
    
    RET
NS_GREEN_LIGHT ENDP

;----North South Yellow Light & East West Red Light----
NS_YELLOW_LIGHT PROC 
    MOV AX, 28Ah
    OUT 4, AX                 
    
    MOV CX, 50 ;t/2
    NSY_LOOP:         
      CALL CHECK_INPUT
      LOOP NSY_LOOP
     
    RET
NS_YELLOW_LIGHT ENDP 

;----North South Red Light & East West Red Light----
ALL_RED_LIGHT PROC
    MOV AX, 249h 
    OUT 4, AX
    
    MOV CX, 25 ;t/4
    RED_LOOP: 
    CALL CHECK_INPUT        
      LOOP RED_LOOP 
      
    ;checking if pedestrian request:
    CMP PED_REQ, 1
    JNE NO_PED     
    
    MOV PED_REQ, 0  ;clearing the request
    
    MOV CX, 1000 ;extend red time for pedestrians
    PED_EXTEND:
      LOOP PED_EXTEND
      
    NO_PED:
      RET
      
ALL_RED_LIGHT ENDP      

;-----North South Red & East West Green Light------
NS_RED_LIGHT PROC              
    MOV AX, 861h 
    OUT 4, AX
    
    MOV CX, 100  ;t
    NSR_LOOP:               
      CALL CHECK_INPUT
      LOOP NSR_LOOP
                
    RET            
NS_RED_LIGHT ENDP

;----North South Red & East West Yellow Light----
EW_YELLOW_LIGHT PROC 
    MOV AX, 451h
    OUT 4, AX                 
    
    MOV CX, 50 ;t/2
    EWY_LOOP:         
      CALL CHECK_INPUT
      LOOP EWY_LOOP
     
    RET
EW_YELLOW_LIGHT ENDP


;----Pedestrian----
PEDESTRIAN_MODE PROC
    MOV AX, 249h 
    OUT 4, AX
    
    MOV CX, 1000 ;10t extended hold for crossing
    P_LOOP:         
      LOOP P_LOOP
    
    RET
PEDESTRIAN_MODE ENDP

;----Emergency----
EMERGENCY_MODE PROC
    MOV AX, 249h  
    OUT 4, AX
    
    MOV CX, 1000 ;10t extended hold for vehicle crossing safely
     E_LOOP:
        LOOP E_LOOP
     
    RET
EMERGENCY_MODE ENDP
