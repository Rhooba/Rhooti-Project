ORG 100h
MAIN PROC
 MAIN_LOOP:   
      CALL GREEN_LIGHT
      CALL CHECK_INPUT
      
      CALL YELLOW_LIGHT
      CALL CHECK_INPUT
      
      CALL RED_LIGHT
      CALL CHECK_INPUT
      
    JMP MAIN_LOOP
    
MAIN ENDP

;----Check Input----
CHECK_INPUT PROC
; Blocking keyboard input using Service 01h.
; Program pauses and waits for a keypress after each light phase.
; Press E/e for Emergency, P/p for Pedestrian, or any other key to continue.

    MOV AH, 01h  ; Service 01h: read key (blocking)
    INT 21h      ; AL = ASCII value of key pressed

    CMP AL, 'E'  ; emergency detected (uppercase)
    JE  EMERGENCY_MODE
    CMP AL, 'e'  ; emergency detected (lowercase)
    JE  EMERGENCY_MODE
      
    CMP AL, 'P'  ; pedestrian detected (uppercase)
    JE  PEDESTRIAN_MODE   
    CMP AL, 'p'  ; pedestrian detected (lowercase)
    JE  PEDESTRIAN_MODE                  

NO_KEY:
    RET  
CHECK_INPUT ENDP

;----Green Light----
; Green = 4 (bit 2 = 00000100)
GREEN_LIGHT PROC  
    MOV AL, 4    ; green (bit 2)
    OUT 4, AL
    
    MOV CX, 500  ; t
    G_LOOP:
        LOOP G_LOOP
    
    RET
GREEN_LIGHT ENDP

;----Yellow Light----
; Yellow = 2 (bit 1 = 00000010)
YELLOW_LIGHT PROC 
    MOV AL, 2    ; yellow (bit 1)
    OUT 4, AL
    
    MOV CX, 250  ; t/2
    Y_LOOP:
        LOOP Y_LOOP
     
    RET
YELLOW_LIGHT ENDP

;-----Red Light------
; Red = 1 (bit 0 = 00000001)
RED_LIGHT PROC
    MOV AL, 1    ; red light (bit 0)
    OUT 4, AL
    
    MOV CX, 500  ; t
    R_LOOP:
        LOOP R_LOOP
                
    RET            
RED_LIGHT ENDP  

;----Pedestrian----
; Called when P pressed.
; Holds red for 3x normal duration for safe crossing.
PEDESTRIAN_MODE PROC
    MOV AL, 1     ; red light (bit 0)
    OUT 4, AL
    
    MOV CX, 1500  ; 3t - extended hold for crossing
    P_LOOP:
        LOOP P_LOOP
    
    RET
PEDESTRIAN_MODE ENDP

;----Emergency----
; Emergency = immediate red override.
; Forces red now regardless of current light.
; Holds for 2t to let emergency vehicle pass.
; Returns to normal cycle after.
EMERGENCY_MODE PROC
    MOV AL, 1     ; red light (bit 0)
    OUT 4, AL
    
    MOV CX, 1000  ; 2t - distinct from pedestrian
    E_LOOP:
        LOOP E_LOOP
     
    RET
EMERGENCY_MODE ENDP
