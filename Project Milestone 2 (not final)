;Now make it for all lights
;NS EW systems
;Use Stack 

ORG 100h

MAIN PROC
 MAIN_LOOP: 
   ;state 1 NS Green & EW Red
   STATE_1:  
      CALL NS_GREEN_LIGHT
      CALL CHECK_INPUT 
      JMP STATE_2
   
   ;state 2 NS Yellow & EW Red     
   STATE_2:    
      CALL NS_YELLOW_LIGHT
      CALL CHECK_INPUT
      JMP STATE_3
   
   ;state 3 all Red for a bit
   STATE_3:   
      CALL ALL_RED_LIGHT
      CALL CHECK_INPUT
      JMP STATE_4   
      
   ;state 4 NS Red & EW Green
   STATE_4: 
      CALL NS_RED_LIGHT
      CALL CHECK_INPUT
      JMP STATE_5   
      
   ;state 5 NS Red & EW Yellow
   STATE_5:
      CALL EW_YELLOW_LIGHT
      CALL CHECK_INPUT
      JMP STATE_6 
      
   ;state 6 all Red for a bit
   STATE_6:
      CALL ALL_RED_LIGHT
      CALL CHECK_INPUT
      JMP STATE_1
      
    JMP MAIN_LOOP
    
MAIN ENDP

;----Check Input----
CHECK_INPUT PROC
   
    MOV AH, 06h 
    MOV DL, 0FFh
    INT 21h
    JZ NO_KEY
    
    CMP AL, 'E' ;emergency detected  
    JE  EMERGENCY
    CMP AL, 'e' ;emergency detected
    JE  EMERGENCY
      
    CMP AL, 'P' ;pedestrian detected
    JE  PEDESTRIAN 
    CMP AL, 'p' ;pedestrian detected
    JE  PEDESTRIAN   

    JMP NO_KEY  
                 
EMERGENCY:
    CALL EMERGENCY_MODE
    JMP MAIN_LOOP
    
PEDESTRIAN:
    CALL PEDESTRIAN_MODE
    JMP MAIN_LOOP 

NO_KEY:
    RET  
CHECK_INPUT ENDP

;---- North South Green Light & East West Red Light---- 
NS_GREEN_LIGHT PROC 
    MOV AX, 30Ch
    OUT 4, AX
  
    MOV CX, 100 ;t 
    NSG_LOOP:           
      CALL CHECK_INPUT
      LOOP NSG_LOOP
    
    RET
NS_GREEN_LIGHT ENDP

;----North South Yellow Light & East West Red Light----
NS_YELLOW_LIGHT PROC 
    MOV AX, 28Ah
    OUT 4, AX                 
    
    MOV CX, 50 ;t/2
    NSY_LOOP:         
      CALL CHECK_INPUT
      LOOP NSY_LOOP
     
    RET
NS_YELLOW_LIGHT ENDP 

;----North South Red Light & East West Red Light----
ALL_RED_LIGHT PROC
    MOV AX, 249h 
    OUT 4, AX
    
    MOV CX, 25 ;t/4
    RED_LOOP: 
    CALL CHECK_INPUT        
      LOOP RED_LOOP  
      
    RET
ALL_RED_LIGHT ENDP      

;-----North South Red & East West Green Light------
NS_RED_LIGHT PROC              
    MOV AX, 861h 
    OUT 4, AX
    
    MOV CX, 100  ;t
    NSR_LOOP:               
      CALL CHECK_INPUT
      LOOP NSR_LOOP
                
    RET            
NS_RED_LIGHT ENDP

;----North South Red & East West Yellow Light----
EW_YELLOW_LIGHT PROC 
    MOV AX, 451h
    OUT 4, AX                 
    
    MOV CX, 50 ;t/2
    EWY_LOOP:         
      CALL CHECK_INPUT
      LOOP EWY_LOOP
     
    RET
EW_YELLOW_LIGHT ENDP


;----Pedestrian----

PEDESTRIAN_MODE PROC
    MOV AX, 249h 
    OUT 4, AX
    
    MOV CX, 1000 ;10t extended hold for crossing
    P_LOOP:         
      LOOP P_LOOP
    
    RET
PEDESTRIAN_MODE ENDP

;----Emergency----
EMERGENCY_MODE PROC
    MOV AX, 249h  
    OUT 4, AX
    
    MOV CX, 1000 ;10t extended hold for vehicle crossing safely
     E_LOOP:
        LOOP E_LOOP
     
    RET
EMERGENCY_MODE ENDP   
